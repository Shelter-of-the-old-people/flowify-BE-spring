{
  "_meta": {
    "version": "1.1.0",
    "updated_at": "2026-05-05"
  },
  "services": [
    {
      "key": "slack",
      "label": "Slack",
      "auth_required": true,
      "accepted_input_types": ["TEXT"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "channel", "label": "채널", "type": "channel_picker", "required": true, "picker_supported": true },
          { "key": "message_format", "label": "메시지 포맷", "type": "select", "options": ["plain", "markdown"], "required": false },
          { "key": "header", "label": "머릿말", "type": "text", "required": false }
        ]
      }
    },
    {
      "key": "gmail",
      "label": "Gmail",
      "auth_required": true,
      "accepted_input_types": ["TEXT", "SINGLE_FILE", "FILE_LIST"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "to", "label": "수신자", "type": "email_input", "required": true },
          { "key": "subject", "label": "제목", "type": "text", "required": true },
          { "key": "body_format", "label": "본문 포맷", "type": "select", "options": ["plain", "html"], "required": false },
          { "key": "action", "label": "동작", "type": "select", "options": ["send", "draft"], "required": true }
        ]
      }
    },
    {
      "key": "notion",
      "label": "Notion",
      "auth_required": true,
      "accepted_input_types": ["TEXT", "SPREADSHEET_DATA", "API_RESPONSE"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "target_type", "label": "저장 위치 유형", "type": "select", "options": ["page", "database"], "required": true },
          { "key": "target_id", "label": "페이지/데이터베이스", "type": "page_picker", "required": true, "picker_supported": true },
          { "key": "title_template", "label": "제목 템플릿", "type": "text", "required": false }
        ]
      }
    },
    {
      "key": "google_drive",
      "label": "Google Drive",
      "auth_required": true,
      "accepted_input_types": ["TEXT", "SINGLE_FILE", "FILE_LIST", "SPREADSHEET_DATA"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "folder_id", "label": "저장 폴더", "type": "folder_picker", "required": true, "picker_supported": true },
          { "key": "filename_template", "label": "파일명 규칙", "type": "text", "required": false },
          { "key": "file_format", "label": "파일 형식", "type": "select", "options": ["pdf", "docx", "txt", "original"], "required": false }
        ]
      }
    },
    {
      "key": "google_sheets",
      "label": "Google Sheets",
      "auth_required": true,
      "accepted_input_types": ["TEXT", "SPREADSHEET_DATA", "API_RESPONSE"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "spreadsheet_id", "label": "스프레드시트", "type": "sheet_picker", "required": true, "picker_supported": false },
          { "key": "sheet_name", "label": "시트 이름", "type": "text", "required": false },
          { "key": "write_mode", "label": "저장 방식", "type": "select", "options": ["append", "overwrite"], "required": true }
        ]
      }
    },
    {
      "key": "google_calendar",
      "label": "Google Calendar",
      "auth_required": true,
      "accepted_input_types": ["TEXT", "SCHEDULE_DATA"],
      "config_schema_scope": "per_service",
      "config_schema": {
        "fields": [
          { "key": "calendar_id", "label": "캘린더", "type": "calendar_picker", "required": true, "picker_supported": false },
          { "key": "event_title_template", "label": "일정 제목 템플릿", "type": "text", "required": true },
          { "key": "duration_minutes", "label": "기본 소요 시간 (분)", "type": "number", "required": false },
          { "key": "action", "label": "동작", "type": "select", "options": ["create", "update"], "required": true }
        ]
      }
    }
  ]
}
